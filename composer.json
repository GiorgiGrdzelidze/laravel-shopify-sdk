{
    "name": "giorgigrdzelidze/laravel-shopify-sdk",
    "description": "Production-grade Laravel 12 package for Shopify Admin API integration with OAuth, webhooks, data mirroring, and optional Filament support",
    "keywords": [
        "laravel",
        "shopify",
        "shopify-api",
        "oauth",
        "webhooks",
        "graphql",
        "rest-api",
        "filament"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Giorgi Grdzelidze",
            "email": "giorgi@example.com",
            "homepage": "https://github.com/GiorgiGrdzelidze"
        }
    ],
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0",
        "guzzlehttp/guzzle": "^7.8",
        "illuminate/support": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/console": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "filament/filament": "^5.0 - Required for optional Filament admin panel integration"
    },
    "autoload": {
        "psr-4": {
            "LaravelShopifySdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelShopifySdk\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelShopifySdk\\ShopifyServiceProvider"
            ],
            "aliases": {
                "Shopify": "LaravelShopifySdk\\Facades\\Shopify"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
